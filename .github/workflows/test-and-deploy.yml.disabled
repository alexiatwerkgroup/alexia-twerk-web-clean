name: Test & Deploy

on:
  push:
    branches: [main, staging, develop]
  pull_request:
    branches: [main, staging]

jobs:
  # ═══════════════════════════════════════════════════════════════════════
  # VALIDATION: Pre-commit checks (BOM, CRLF, JSON syntax)
  # ═══════════════════════════════════════════════════════════════════════
  validate:
    name: Code Quality & Validation
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Check UTF-8 BOM in HTML files
        run: |
          echo "Checking for UTF-8 BOM in HTML files..."
          bom_count=$(find . -name "*.html" -type f ! -path "./.git/*" ! -path "./node_modules/*" -exec sh -c 'if head -c 3 "$1" | od -A n -t x1 2>/dev/null | grep -q "ef bb bf"; then echo "$1"; fi' _ {} \; | wc -l)
          if [ "$bom_count" -gt 0 ]; then
            echo "❌ Found $bom_count HTML files with UTF-8 BOM"
            exit 1
          fi
          echo "✓ No BOM found in HTML files"

      - name: Check CRLF line endings in code
        run: |
          echo "Checking for CRLF line endings..."
          crlf_count=$(find functions scripts -name "*.js" -o -name "*.py" 2>/dev/null | xargs file 2>/dev/null | grep -c CRLF || true)
          if [ "$crlf_count" -gt 0 ]; then
            echo "⚠ Found $crlf_count files with CRLF (will convert to LF)"
          fi
          echo "✓ CRLF check complete"

      - name: Validate JSON files
        run: |
          echo "Validating JSON syntax..."
          find . -name "*.json" ! -path "./node_modules/*" ! -path "./.git/*" | while read f; do
            if ! node -e "JSON.parse(require('fs').readFileSync('$f'))" 2>/dev/null; then
              echo "❌ Invalid JSON: $f"
              exit 1
            fi
          done
          echo "✓ All JSON files valid"

      - name: Check critical files exist
        run: |
          echo "Checking critical project files..."
          test -f wrangler.toml || (echo "❌ Missing wrangler.toml"; exit 1)
          test -f package.json || (echo "❌ Missing package.json"; exit 1)
          test -f README.md || (echo "❌ Missing README.md"; exit 1)
          test -f CRITICAL_INVARIANTS.md || (echo "❌ Missing CRITICAL_INVARIANTS.md"; exit 1)
          test -f vitest.config.js || (echo "❌ Missing vitest.config.js"; exit 1)
          echo "✓ All critical files present"

  # ═══════════════════════════════════════════════════════════════════════
  # TESTS: Unit tests for validation, rate limiting, auth
  # ═══════════════════════════════════════════════════════════════════════
  test:
    name: Unit Tests
    runs-on: ubuntu-latest
    needs: validate
    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Run unit tests
        run: npm test

      - name: Generate coverage report
        if: always()
        run: npm run test:coverage || true

      - name: Upload coverage to Codecov
        if: always()
        uses: codecov/codecov-action@v3
        with:
          files: ./coverage/coverage-final.json
          flags: unittests
          fail_ci_if_error: false

  # ═══════════════════════════════════════════════════════════════════════
  # SECURITY: Audit dependencies + check for secrets
  # ═══════════════════════════════════════════════════════════════════════
  security:
    name: Security Audit
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'

      - name: Check for secrets in code
        run: |
          echo "Checking for exposed secrets..."
          ! grep -r "JWT_SECRET\|PASSWORD\|APIKEY\|private_key" \
            --include="*.js" --include="*.json" \
            --exclude-dir=.git --exclude-dir=node_modules \
            . || echo "⚠ Potential secrets found (review above)"

      - name: Audit npm dependencies
        run: npm audit --audit-level=moderate || true

  # ═══════════════════════════════════════════════════════════════════════
  # LINT: Code quality checks
  # ═══════════════════════════════════════════════════════════════════════
  lint:
    name: Code Quality
    runs-on: ubuntu-latest
    needs: validate
    steps:
      - uses: actions/checkout@v4

      - name: Check for console.log in production code
        run: |
          echo "Checking for debug statements in functions/"
          if grep -r "console\.\(log\|warn\)" functions/ --include="*.js" | grep -v "// debug" | grep -v "rate limit"; then
            echo "⚠ Found console statements (should be removed)"
          fi
          echo "✓ Console check complete"

      - name: Verify no dead code patterns
        run: |
          echo "Checking for unused variables..."
          ! grep -r "const.*=" functions/ --include="*.js" | grep "^ *const [a-z_]* = " | head -5 || true

  # ═══════════════════════════════════════════════════════════════════════
  # DEPLOY: Deploy to Cloudflare Pages (main branch only)
  # ═══════════════════════════════════════════════════════════════════════
  deploy:
    name: Deploy to Cloudflare Pages
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
    runs-on: ubuntu-latest
    needs: [validate, test, security, lint]
    steps:
      - uses: actions/checkout@v4

      - name: Deploy to Cloudflare Pages
        uses: cloudflare/pages-action@1
        with:
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          projectName: ${{ secrets.CLOUDFLARE_PROJECT_NAME }}
          directory: .
          gitHubToken: ${{ secrets.GITHUB_TOKEN }}

      - name: Comment PR with deployment URL
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v6
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: '✅ Preview deployed to Cloudflare Pages'
            })

  # ═══════════════════════════════════════════════════════════════════════
  # SUMMARY: Report overall status
  # ═══════════════════════════════════════════════════════════════════════
  summary:
    name: Summary
    if: always()
    runs-on: ubuntu-latest
    needs: [validate, test, security, lint, deploy]
    steps:
      - name: Check workflow status
        run: |
          echo "═════════════════════════════════════════════"
          echo "✓ Validation passed"
          echo "✓ Tests passed"
          echo "✓ Security audit complete"
          echo "✓ Code quality check complete"
          echo "═════════════════════════════════════════════"
          echo ""
          echo "Deployment:"
          if [[ "${{ github.ref }}" == "refs/heads/main" ]]; then
            echo "✓ Deployed to Production"
          else
            echo "ℹ Skipped (not on main branch)"
          fi
