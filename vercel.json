{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home.html", "destination": "/", "permanent": true },
    { "source": "/es/playlist", "destination": "/playlist/", "permanent": true },
    { "source": "/es/playlist/", "destination": "/playlist/", "permanent": true },
    { "source": "/es/playlist/index.html", "destination": "/playlist/", "permanent": true },
    { "source": "/twerk-dancer", "destination": "/creators.html", "permanent": true },
    { "source": "/twerk-dancer/", "destination": "/creators.html", "permanent": true },
    { "source": "/twerk-dancer/index.html", "destination": "/creators.html", "permanent": true },
    { "source": "/models-catalog.html", "destination": "/", "permanent": true },
    { "source": "/variety-catalog.html", "destination": "/", "permanent": true },
    { "source": "/playlist-del-otro-lado", "destination": "/", "statusCode": 410 },
    { "source": "/playlist-del-otro-lado.html", "destination": "/", "statusCode": 410 },
    { "source": "/playlist-try-on-hot-leaks", "destination": "/try-on-hot-leaks/", "permanent": true },
    { "source": "/playlist-try-on-hot-leaks/(.*)", "destination": "/try-on-hot-leaks/$1", "permanent": true },
    { "source": "/playlist-hottest-cosplay-fancam", "destination": "/hottest-cosplay-fancam/", "permanent": true },
    { "source": "/playlist-hottest-cosplay-fancam/(.*)", "destination": "/hottest-cosplay-fancam/$1", "permanent": true },
    { "source": "/playlist-korean-girls-kpop-twerk", "destination": "/korean-girls-kpop-twerk/", "permanent": true },
    { "source": "/playlist-korean-girls-kpop-twerk/(.*)", "destination": "/korean-girls-kpop-twerk/$1", "permanent": true },

    { "source": "/playlist-twerk-hub-leaks", "destination": "/twerk-hub-leaks/", "permanent": true },
    { "source": "/playlist-twerk-hub-leaks.html", "destination": "/twerk-hub-leaks/", "permanent": true },
    { "source": "/playlist-twerk-hub-leaks/(.*)", "destination": "/twerk-hub-leaks/$1", "permanent": true },
    { "source": "/playlist-cosplay-fancam-leaks", "destination": "/cosplay-fancam-leaks/", "permanent": true },
    { "source": "/playlist-cosplay-fancam-leaks.html", "destination": "/cosplay-fancam-leaks/", "permanent": true },
    { "source": "/playlist-cosplay-fancam-leaks/(.*)", "destination": "/cosplay-fancam-leaks/$1", "permanent": true },
    { "source": "/playlist-korean", "destination": "/korean-girls-kpop-twerk/", "permanent": true },
    { "source": "/playlist-korean.html", "destination": "/korean-girls-kpop-twerk/", "permanent": true },
    { "source": "/playlist-korean/(.*)", "destination": "/korean-girls-kpop-twerk/$1", "permanent": true },
    { "source": "/playlist-try-on-haul-leaks", "destination": "/try-on-hot-leaks/", "permanent": true },
    { "source": "/playlist-try-on-haul-leaks.html", "destination": "/try-on-hot-leaks/", "permanent": true },
    { "source": "/playlist-try-on-haul-leaks/(.*)", "destination": "/try-on-hot-leaks/$1", "permanent": true },
    { "source": "/playlist-latina-model-leaks", "destination": "/ttl-latin-models/", "permanent": true },
    { "source": "/playlist-latina-model-leaks.html", "destination": "/ttl-latin-models/", "permanent": true },
    { "source": "/playlist-latina-model-leaks/(.*)", "destination": "/ttl-latin-models/$1", "permanent": true },

    { "source": "/playlist-model-1.html", "destination": "/playlist/", "permanent": true },
    { "source": "/playlist-model-1-dark-premium.html", "destination": "/playlist/", "permanent": true },
    { "source": "/playlist-recently-added.html", "destination": "/playlist/", "permanent": true },
    { "source": "/twerk-hub-leaks.html", "destination": "/twerk-hub-leaks/", "permanent": true },
    { "source": "/ttl-latin-models.html", "destination": "/ttl-latin-models/", "permanent": true },
    { "source": "/korean.html", "destination": "/korean-girls-kpop-twerk/", "permanent": true },
    { "source": "/kpop-twerk.html", "destination": "/korean-girls-kpop-twerk/", "permanent": true },
    { "source": "/alexia-twerk.html", "destination": "/alexia-twerk-leaks.html", "permanent": true },
    { "source": "/twerk-leaks.html", "destination": "/alexia-twerk-leaks.html", "permanent": true },
    { "source": "/creator", "destination": "/creators.html", "permanent": true },
    { "source": "/creator/", "destination": "/creators.html", "permanent": true },
    { "source": "/models", "destination": "/playlist/", "permanent": true },
    { "source": "/models/", "destination": "/playlist/", "permanent": true },
    { "source": "/studios", "destination": "/twerk-studios.html", "permanent": true },
    { "source": "/studios/", "destination": "/twerk-studios.html", "permanent": true },

    { "source": "/premium-cosplay-fancam", "destination": "/hottest-cosplay-fancam/", "permanent": true },
    { "source": "/premium-cosplay-fancam.html", "destination": "/hottest-cosplay-fancam/", "permanent": true },
    { "source": "/premium-cosplay-fancam/", "destination": "/hottest-cosplay-fancam/", "permanent": true },
    { "source": "/premium-cosplay-fancam/(.*)", "destination": "/hottest-cosplay-fancam/$1", "permanent": true }
  ]
}
