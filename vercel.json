{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/home.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/models-catalog.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/variety-catalog.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/playlist-del-otro-lado",
      "destination": "/",
      "statusCode": 410
    },
    {
      "source": "/playlist-del-otro-lado.html",
      "destination": "/",
      "statusCode": 410
    },
    {
      "source": "/playlist-2",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-2/",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-2/:path*",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-korean.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-try-on-haul-leaks.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-latina-model-leaks.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-twerk-hub-leaks.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-twerk-hub.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-cosplay-fancam-leaks.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/playlist-ttl-4k-leaks.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/premium-kdance-archive.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/premium-latina-beauties.html",
      "destination": "/playlist/",
      "permanent": true
    },
    {
      "source": "/premium-try-on-haul.html",
      "destination": "/playlist/",
      "permanent": true
    }
  ]
}
