# TWERKHUB · gitattributes — encoding + EOL hardening
# Forces UTF-8 (no BOM) + LF for all text files. Prevents PowerShell cp1252 corruption.

# Default: LF normalization for everything Git considers text
* text=auto eol=lf

# Source files — explicit text + LF
*.html      text eol=lf working-tree-encoding=UTF-8
*.css       text eol=lf working-tree-encoding=UTF-8
*.js        text eol=lf working-tree-encoding=UTF-8
*.mjs       text eol=lf working-tree-encoding=UTF-8
*.json      text eol=lf working-tree-encoding=UTF-8
*.xml       text eol=lf working-tree-encoding=UTF-8
*.svg       text eol=lf working-tree-encoding=UTF-8
*.md        text eol=lf working-tree-encoding=UTF-8
*.txt       text eol=lf working-tree-encoding=UTF-8
*.yml       text eol=lf working-tree-encoding=UTF-8
*.yaml      text eol=lf working-tree-encoding=UTF-8
*.py        text eol=lf working-tree-encoding=UTF-8
*.sh        text eol=lf working-tree-encoding=UTF-8

# Windows-only scripts — keep CRLF
*.ps1       text eol=crlf working-tree-encoding=UTF-8
*.bat       text eol=crlf working-tree-encoding=UTF-8
*.cmd       text eol=crlf working-tree-encoding=UTF-8

# Binary — never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.mp3       binary
*.mp4       binary
*.webm      binary
*.woff      binary
*.woff2     binary
*.zip       binary
*.gz        binary
*.pdf       binary
*.pyc       binary
