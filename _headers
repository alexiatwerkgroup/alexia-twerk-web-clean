# Cloudflare Pages / Vercel headers (updated 2026-05-06)
# Lighthouse Best Practices: HSTS, COOP, XFO, CSP, X-Content-Type-Options

/*
  Cache-Control: public, max-age=0, must-revalidate
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://*.youtube.com https://*.youtube-nocookie.com https://*.gstatic.com https://*.cloudflare.com https://challenges.cloudflare.com https://ecdwm.com https://*.ecdwm.com https://atwmcd.com https://*.atwmcd.com https://*.livejasmin.com https://*.lsl.com https://*.awejmp.com https://*.dditscdn.com https://*.lj-i.net https://*.iconnect7.com https://m1.nsimg.net https://*.nsimg.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.ecdwm.com https://*.atwmcd.com https://*.livejasmin.com https://*.nsimg.net; font-src 'self' https://fonts.gstatic.com data: https://*.nsimg.net https://*.atwmcd.com; img-src 'self' data: blob: https:; media-src 'self' https: blob:; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://*.cloudflare.com https://challenges.cloudflare.com https://*.supabase.co wss://*.supabase.co https://ecdwm.com https://*.ecdwm.com https://atwmcd.com https://*.atwmcd.com https://*.livejasmin.com https://*.lsl.com https://*.nsimg.net https://*.awejmp.com https://*.dditscdn.com wss://*.atwmcd.com wss://*.livejasmin.com; frame-src 'self' https://*.youtube.com https://*.youtube-nocookie.com https://challenges.cloudflare.com https://*.chaturbate.com https://chaturbate.com https://*.mmcdn.com https://*.highwebmedia.com https://ecdwm.com https://*.ecdwm.com https://atwmcd.com https://*.atwmcd.com https://*.livejasmin.com https://*.lsl.com https://*.nsimg.net https://*.awejmp.com https://*.dditscdn.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https:; frame-ancestors 'self'; upgrade-insecure-requests

/manifest.json
  Content-Type: application/json
  Cache-Control: no-cache, no-store, must-revalidate

/service-worker.js
  Content-Type: application/javascript
  Cache-Control: no-cache, no-store, must-revalidate

# Real-time counter scripts — must always be fresh so bug fixes take effect immediately
/assets/online-count-global.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

/assets/global-nav-online.js
  Cache-Control: no-cache, must-revalidate
  Content-Type: application/javascript

# Scripts/CSS — revalidar siempre para que cada deploy se vea sin purgar caché.
# (Antes era immutable+1año, que dejaba versiones viejas pegadas para siempre.)
/assets/*
  Cache-Control: public, max-age=0, must-revalidate

# Fonts — immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
